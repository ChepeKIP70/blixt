{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Blixt",
  "version": "0.1.0",
  "identifier": "app.blixt",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "title": "Blixt",
        "width": 360,
        "height": 340,
        "decorations": false,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "center": true
      },
      {
        "label": "settings",
        "url": "settings.html",
        "title": "Blixt - Einstellungen",
        "width": 500,
        "height": 680,
        "resizable": false,
        "visible": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
